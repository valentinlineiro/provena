{
  "name": "provena",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/cli",
    "build:all": "npm run build -w packages/cli",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test packages/*/src/*.test.ts",
    "demo": "tsx packages/cli/src/index.ts render examples/valen --stdout",
    "provena": "tsx packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
